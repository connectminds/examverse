{
  "name": "examverse",
  "version": "1.0.0",
  "description": "ExamVerse - Smart exam platform with offline support, real-time analytics, and AI-powered questions.",
  "main": "electron-src/main.js",
  "preload": "electron-src/preload.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "electron:build:dir": "electron-builder --dir",
    "electron:pack": "electron-builder --dir --publish never",
    "electron:dist": "electron-builder --publish never",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "examverse",
    "email",
    "notifications",
    "nodemailer",
    "express"
  ],
  "author": "Connectminds IT TECH",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "app-builder-bin": "^5.0.0-alpha.12",
    "electron": "42.3.0",
    "electron-builder": "26.8.1",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "6.8.3",
    "nodemon": "^3.0.2"
  },
  "build": {
    "appId": "com.connectminds.examverse",
    "productName": "ExamVerse",
    "directories": {
      "app": ".",
      "output": "dist"
    },
    "files": [
      "**/*",
      "!www/**"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://connectminds.tech/updates/examverse/"
      }
    ]
  }
}
