# ExamVerse Email Service Configuration
# Copy this file to .env and fill in your actual values

# Server
PORT=5000
NODE_ENV=development

# Email Configuration (Using Gmail as example)
EMAIL_SERVICE=gmail
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-specific-password

# Alternative: Using SMTP directly
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# App URLs
APP_URL=https://examverse.yourapp.com
UNSUBSCRIBE_URL=https://examverse.yourapp.com/unsubscribe

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Notes for Gmail:
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Generate an App Password at myaccount.google.com/apppasswords
# 3. Use the 16-character app password in EMAIL_PASS (without spaces)
#
# For other email providers (SendGrid, Mailgun, Office365, etc.):
# Update EMAIL_SERVICE and credentials accordingly
#
# SendGrid Example:
# EMAIL_SERVICE=SendGrid
# EMAIL_USER=apikey
# EMAIL_PASS=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Mailgun Example:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USER=postmaster@yourdomain.mailgun.org
# EMAIL_PASS=your-mailgun-password
